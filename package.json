{
  "name": "@tollerud/ui",
  "version": "1.3.0",
  "description": "Tollerud User Interface — dark, monochrome + yellow accent. Noir aesthetic meets modern utility.",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tollerud/ui.git"
  },
  "homepage": "https://tollerud.github.io/design-system/",
  "bugs": {
    "url": "https://github.com/Tollerud/ui/issues"
  },
  "license": "MIT",
  "author": "Mathias Tollerud <mathias.tollerud@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./globals.css": "./globals.css",
    "./globals-v3.css": "./globals-v3.css",
    "./globals-v4.css": "./globals-v4.css",
    "./globals-layers.css": "./globals-layers.css",
    "./tokens.css": "./tokens.css",
    "./preset": "./tollerud-preset.js",
    "./tollerud-logo.svg": "./tollerud-logo.svg",
    "./tollerud-avatar.svg": "./tollerud-avatar.svg",
    "./tollerud-avatar.png": "./tollerud-avatar.png",
    "./tia-full-figure.svg": "./tia-full-figure.svg",
    "./registry.json": "./registry.json",
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "files": [
    "dist",
    "globals.css",
    "globals-v3.css",
    "globals-v4.css",
    "globals-layers.css",
    "tokens.css",
    "tollerud-preset.js",
    "registry.json",
    "components.json",
    "GETTING_STARTED.md",
    "COMPONENTS.md",
    "CHANGELOG.md",
    "tollerud-logo.svg",
    "tollerud-avatar.svg",
    "tollerud-avatar.png",
    "tia-full-figure.svg",
    "AGENTS.md",
    "SKILL.md"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-entries.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:subpath": "node scripts/verify-subpath-exports.mjs",
    "test:drift": "node scripts/verify-registry-drift.mjs",
    "test:consumer": "node scripts/test-consumer.mjs",
    "changelog:draft": "node scripts/changelog-draft.mjs",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build && npm run test:subpath && npm run test:drift && npm run build:docs && npm run test:consumer",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build && npm run test:subpath && npm run test:drift",
    "build:docs": "node scripts/build-docs.mjs",
    "preview:docs": "npx --yes serve _site -l 4173",
    "preview": "open preview.html"
  },
  "peerDependencies": {
    "@paper-design/shaders-react": "^0.0.76",
    "clsx": "^2.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwind-merge": "^2.0.0 || ^3.0.0",
    "tailwindcss": "^4.0.0 || ^3.4.0"
  },
  "peerDependenciesMeta": {
    "@paper-design/shaders-react": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "tollerud",
    "design-system",
    "react",
    "tailwind",
    "dark-theme",
    "monochrome",
    "noir",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  }
}
