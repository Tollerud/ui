{
  "name": "@tollerud/email",
  "version": "4.11.0",
  "description": "Tollerud branded email primitives + templates — React Email, tokens synced from @tollerud/ui",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tollerud/ui.git",
    "directory": "packages/email"
  },
  "homepage": "https://design.tollerud.dev/",
  "license": "MIT",
  "author": "Mathias Tollerud <mathias@tollerud.no>",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
